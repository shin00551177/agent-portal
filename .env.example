# .env.example — document every required environment variable by NAME only.
# Never put real values here. Real secrets live in Railway environment variables or .env.local (gitignored).

# --- Portal auth (REQUIRED — app crashes on startup if missing) ---
# SESSION_SECRET=            # random 40+ char string for session token hashing
# PORTAL_PASSWORD=           # login password for the portal UI

# --- Portal API (REQUIRED for agent-to-portal writes) ---
# PORTAL_API_KEY=            # used by external agents posting proposals (x-api-key header)
# CRON_SECRET=               # used by cron job authentication (Bearer token)
# SYNC_SECRET=               # used by sync endpoints

# --- Database (REQUIRED) ---
# DATABASE_URL=              # PostgreSQL connection string

# --- Apple App Store Connect (REQUIRED for iOS ASO) ---
# APPLE_IAP_ISSUER_ID=       # App Store Connect issuer ID
# APPLE_IAP_KEY_ID=          # App Store Connect key ID
# APPLE_IAP_PRIVATE_KEY_B64= # base64-encoded .p8 private key

# --- Google Play (REQUIRED for Android ASO) ---
# GOOGLE_SERVICE_ACCOUNT_JSON=  # JSON string of Google service account credentials

# --- ASO data sources ---
# APPTWEAK_API_KEY=          # Apptweak keyword ranking data

# --- SNS / content research ---
# YOUTUBE_API_KEY=           # YouTube Data API v3
# GOOGLE_CSE_KEY=            # Google Custom Search API key
# GOOGLE_CSE_ID=             # Google Custom Search engine ID

# --- AI ---
# GEMINI_API_KEY=            # Google Gemini API (content generation)

# --- GitHub (for workflow dispatch) ---
# GITHUB_TOKEN=              # GitHub personal access token with workflow scope
# GITHUB_REPO=               # target repo (owner/repo format)

# --- Slack ---
# SLACK_BOT_TOKEN=           # bot token with chat:write scope
# SLACK_ASO_CHANNEL=         # channel ID for ASO alerts

# --- Railway (auto-injected, do not set manually) ---
# RAILWAY_PUBLIC_DOMAIN=     # injected by Railway at runtime
# NODE_ENV=                  # injected by Railway (production/development)
# Meta / Instagram (SNS Agent No.5/6)
# META_SYSTEM_USER_TOKEN=    # System User token (never expires) — from Wang-kun, Meta Business Manager
# META_IG_BUSINESS_ID=       # Instagram Business Account ID (@twomijp)
# META_FB_PAGE_ID=           # Facebook Page ID (Twomi Japan)
