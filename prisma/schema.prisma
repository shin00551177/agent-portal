generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AsoApp {
  id           String       @id
  name         String
  googlePlayId String?
  iosId        String?
  country      String       @default("jp")
  language     String       @default("ja")
  active         Boolean @default(false)
  workflowStates Json    @default("{}")
  // Governance (行動規範 #8/#12/#13)
  escalationRules  Json   @default("{}")
  haltConditions   Json   @default("{}")
  fallbackBehavior String @default("pause")
  // Agent台帳 (運用ポリシー §5)
  agentMeta        Json   @default("{}")
  // 連続エラーカウンター (#12 停止条件)
  consecutiveErrors Int   @default(0)
  keywords       AsoKeyword[]
  reports      AsoReport[]
  releases     AsoRelease[]
  reviews      AsoReview[]
  createdAt    DateTime     @default(now())
}

model AsoKeyword {
  id        String   @id @default(cuid())
  appId     String
  app       AsoApp   @relation(fields: [appId], references: [id])
  keyword   String
  priority  String   @default("medium")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([appId, keyword])
}

model AsoReport {
  id        String   @id @default(cuid())
  appId     String
  app       AsoApp   @relation(fields: [appId], references: [id])
  date      String
  data      Json
  slackSent Boolean  @default(false)
  // §8 ストア指標（Backend Base Spec準拠）
  store            String?  // "apple" | "google"
  country          String?  // ISO country code
  storeImpressions Int?
  storePageViews   Int?
  downloads        Int?
  source           String?  // "organic" | "paid" | "unknown"
  lookerSyncedAt   DateTime?
  createdAt DateTime @default(now())
}

model AsoRelease {
  id          String   @id @default(cuid())
  appId       String
  app         AsoApp   @relation(fields: [appId], references: [id])
  releaseDate String
  notes       String?
  effectData  Json?
  createdAt   DateTime @default(now())
}

model SnsApp {
  id        String       @id
  name      String
  active    Boolean      @default(false)
  platforms Json
  locale    String       @default("ja")
  // Governance (行動規範 #8/#12/#13)
  escalationRules  Json   @default("{}")
  haltConditions   Json   @default("{}")
  fallbackBehavior String @default("pause")
  // Agent台帳 (運用ポリシー §5)
  agentMeta        Json   @default("{}")
  drafts       SnsDraft[]
  egoHits      EgoHit[]
  accounts     SnsAccount[]
  refVideos    SnsRefVideo[]
  patterns     SnsPattern[]
  scripts      SnsScript[]
  briefs       SnsBrief[]
  hypotheses       SnsHypothesis[]
  productFeedbacks SnsProductFeedback[]
  frequencyRecs    SnsFrequencyRecommendation[]
  learnings        SnsLearning[]
  createdAt DateTime     @default(now())
}

model SnsRefVideo {
  id          String   @id @default(cuid())
  appId       String
  app         SnsApp   @relation(fields: [appId], references: [id])
  url         String
  platform    String
  account     String?
  title       String?
  views       Int?
  likes       Int?
  comments    Int?
  shares      Int?
  duration    Int?
  postedDate  String?
  hashtags    String?
  bgm         String?
  thumbnail   String?
  // AI分析結果
  analyzed    Boolean  @default(false)
  targetAge   String?
  category    String?
  creatorType String?
  visualType  String?
  tempo       String?
  hook        String?
  structure   String?
  ctaContent  String?
  ctaTiming   String?
  whyBuzz     String?
  credibility String?
  peakMoment  String?
  twomiIdea   String?
  twomiScript String?
  aiComment   String?
  createdAt   DateTime @default(now())

  @@index([appId, analyzed])
}

model SnsScript {
  id              String   @id @default(cuid())
  appId           String
  app             SnsApp   @relation(fields: [appId], references: [id])
  platform        String
  targetAge       String?
  title           String
  hook            String?
  scriptContent   String?
  productionNotes String?
  imagePrompts    String?
  refVideoId      String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())

  @@index([appId])
}

model SnsBrief {
  id               String   @id @default(cuid())
  appId            String
  app              SnsApp   @relation(fields: [appId], references: [id])
  platform         String
  targetAge        String?
  scriptContent    String
  captions         Json     @default("[]")
  higgsfieldPrompt String?
  status           String   @default("draft")
  createdAt        DateTime @default(now())

  @@index([appId])
}

model SnsPattern {
  id           String   @id @default(cuid())
  appId        String
  app          SnsApp   @relation(fields: [appId], references: [id])
  title        String
  platform     String?
  targetAge    String?
  patternType  String
  description  String
  exampleHooks Json     @default("[]")
  createdAt    DateTime @default(now())

  @@index([appId])
}

model SnsAccount {
  id        String   @id @default(cuid())
  appId     String
  app       SnsApp   @relation(fields: [appId], references: [id])
  platform  String
  username  String
  url       String?
  memo      String?
  createdAt DateTime @default(now())
}

model SnsDraft {
  id          String   @id @default(cuid())
  appId       String
  app         SnsApp   @relation(fields: [appId], references: [id])
  platform    String
  copy        String
  hashtags    Json
  imagePrompt  String?
  imageUrl     String?
  imageStatus  String?   // null=no_prompt | "generating" | "done" | "error"
  notes        String?
  status       String   @default("pending")
  // Governance (行動規範 #11)
  confidence    String   @default("medium")
  dataFreshness DateTime?
  createdAt   DateTime @default(now())
}

model EgoHit {
  id           String    @id @default(cuid())
  appId        String?
  app          SnsApp?   @relation(fields: [appId], references: [id])
  source       String
  keyword      String
  title        String
  url          String
  snippet      String?
  author       String?
  score        Int
  publishedAt  DateTime?
  dismissed    Boolean   @default(false)
  // classification
  category     String?   // "buzz" | "feedback" | "other"
  sentiment    String?   // "positive" | "negative" | "neutral"
  feedbackType String?   // "bug" | "feature_request" | "praise" | "comparison"
  engagement   Json?     // { views, likes, reposts, comments }
  createdAt    DateTime  @default(now())
}

// --------------------------------------------------------------------------
// SNS PDCA — 仮説 / ユーザーFB / 投稿頻度レコメンド
// --------------------------------------------------------------------------

model SnsHypothesis {
  id             String    @id @default(cuid())
  appId          String
  app            SnsApp    @relation(fields: [appId], references: [id])
  platform       String
  hypothesis     String    // バズる仮説（1〜2文）
  reasoning      String    // 根拠（エゴサデータ・過去分析）
  targetAudience String?
  format         String?   // 動画/画像/テキスト + トーン
  contentBrief   String?   // Content-lab向けブリーフ
  status         String    @default("pending") // pending|approved|rejected|briefed|posted|measured
  rejectionNote  String?
  metrics        Json?     // 投稿後の成果データ
  briefSentAt    DateTime?
  postedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([appId, status])
}

model SnsProductFeedback {
  id         String   @id @default(cuid())
  appId      String
  app        SnsApp   @relation(fields: [appId], references: [id])
  source     String   // appstore|playstore|x|instagram|etc
  type       String   // bug|feature_request|praise|comparison|general
  content    String
  url        String?
  author     String?
  importance String   @default("medium") // high|medium|low
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([appId, processed])
}

model SnsFrequencyRecommendation {
  id                   String    @id @default(cuid())
  appId                String
  app                  SnsApp    @relation(fields: [appId], references: [id])
  platform             String
  currentFrequency     Int?      // 現在の週投稿数
  recommendedFrequency Int       // AIレコメンド
  reasoning            String
  acceptedAt           DateTime?
  adjustedFrequency    Int?      // 人間の調整値
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([appId, platform])
  @@index([appId])
}

model SnsLearning {
  id        String   @id @default(cuid())
  appId     String
  app       SnsApp   @relation(fields: [appId], references: [id])
  type      String   // "avoid" | "prioritize" | "general"
  content   String
  platform  String?  // null=全体 or "tiktok" | "x" | "instagram" etc.
  source    String   @default("human") // "human" | "ai_synthesis"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appId, active])
}

// --------------------------------------------------------------------------
// 改善ループ: 分析 → 提案 → 承認 → 実行
// --------------------------------------------------------------------------

model AnalysisRun {
  id          String     @id @default(cuid())
  domain      String     // "aso" | "sns" | "ego" | "all"
  targetId    String?    // app ID（特定アプリに絞った場合）
  status      String     @default("running") // "running" | "done" | "failed"
  summary     String?    // 分析サマリー（自然文）
  proposals   Proposal[]
  createdAt   DateTime   @default(now())
  finishedAt  DateTime?
}

model Proposal {
  id           String       @id @default(cuid())

  // 対象
  domain       String       // "aso" | "sns" | "ego" | "general"
  targetType   String?      // "aso_app" | "sns_app" | null（横断的な提案）
  targetId     String?      // アプリID
  store        String?      // "ios" | "android" | null（共通）

  // 提案内容
  title        String
  summary      String       // 1〜2文のインボックス表示用
  rationale    String       // 根拠となる分析（長文可）

  // 意思決定構造
  decisionType String       @default("yesno") // "yesno" | "choice"
  options      Json?        // [{ id, label, description }]（choice時）

  // ステータス
  status       String       @default("pending") // "pending" | "approved" | "rejected" | "executing" | "done" | "failed"
  decision     String?      // "yes" | "no" | option.id
  decidedAt    DateTime?
  rejectionReason String?   // 差し戻し理由（#7 学習ループ）

  // 実行
  actionType   String       // "add_keywords" | "update_setting" | "github_workflow" | "manual"
  actionPayload Json?       // 実行パラメータ
  executedAt   DateTime?
  result       Json?        // 実行結果

  // Governance (行動規範 #11)
  confidence    String    @default("medium")
  dataFreshness DateTime?

  // プロバナンス
  sourceJobId  String?
  analysisRun  AnalysisRun? @relation(fields: [sourceJobId], references: [id])
  sourceData   Json?        // 根拠となった生データ

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([domain, targetId])
  @@index([sourceJobId])
}

// ASO レビュー管理
model AsoReview {
  id               String   @id @default(cuid())
  appId            String
  app              AsoApp   @relation(fields: [appId], references: [id])
  platform         String   // "ios" | "android"
  reviewId         String
  rating           Int
  title            String   @default("")
  body             String
  authorName       String   @default("")
  reviewDate       String
  language         String   @default("")
  territory        String   @default("")
  replyText        String?
  replyDate        String?
  aiReplySuggestion String?
  fetchedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([appId, platform, reviewId])
  @@index([appId, platform])
  @@index([rating])
}

// §7 監査ログ (Backend Base Spec 準拠 / 行動規範 #9)
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "proposal_approved" | "proposal_rejected" | "setting_changed" | "agent_toggled" | "governance_review_sent"
  targetTable String   // "Proposal" | "SnsApp" | "AsoApp"
  targetId    String
  beforeValue Json?
  afterValue  Json?
  performedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([targetTable, targetId])
  @@index([performedAt])
}
